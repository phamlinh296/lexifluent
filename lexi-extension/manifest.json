{
  "manifest_version": 3,
  "name": "LexiFluent — Highlight to Flashcard",
  "version": "1.0.0",
  "description": "Bôi đen từ bất kỳ trang nào → tạo flashcard LexiFluent",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://api.dictionaryapi.dev/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "LexiFluent"
  }
}
